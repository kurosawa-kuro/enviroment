# ===========================================
# Environment Variables Template
# ===========================================
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ===========================================

# ① 実行モード / 環境制御（最上位）
APP_ENV=local                    # local | development | production
APP_MODE=origin                  # origin（開発・検証）| stable（本番・凍結）

# ② サーバー / アプリ基本設定
PORT=3000
LOG_LEVEL=debug                  # debug | info | warn | error

# ③ 認証・認可（Clerk / 内部API）
AUTH_ENABLED=false               # true | false
AUTH_JWT_SECRET=your-jwt-secret-here
AUTH_CLERK_PUBLISHABLE_KEY=pk_xxx
AUTH_CLERK_SECRET_KEY=sk_xxx

# ④ データベース
DB_MONGODB_URI=mongodb://localhost:27017/your-db-name
DB_MONGODB_DB_NAME=your-db-name
DB_NEON_URI=postgresql://user:pass@host/dbname

# ⑤ AWS（Read / 管理系）
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-northeast-1

# ⑥ GitHub / CI・自動化
GIT_GITHUB_ACCESS_TOKEN=ghp_xxx

# ⑦ AI / LLM（共通）- 直接使用禁止、LLM-GW 経由で使用
AI_OPENAI_API_KEY=sk-xxx
AI_ANTHROPIC_API_KEY=sk-ant-xxx
AI_DEEPSEEK_API_KEY=ds-xxx
AI_KAGGLE_TOKEN=xxx

# ⑧ LLM-GW（防御用・重要 - 破産防止ライン）
LLM_GW_ENABLED=false             # true | false
LLM_GW_PROJECT_API_KEY=llm_proj_xxx
LLM_GW_MAX_TOKENS_PER_REQUEST=2048
LLM_GW_DAILY_TOKEN_LIMIT=10000
LLM_GW_MONTHLY_TOKEN_LIMIT=300000
LLM_GW_RATE_LIMIT_PER_MINUTE=10
LLM_GW_RATE_LIMIT_PER_HOUR=100

# ⑨ アラート / 監視
ALERT_ENABLED=false              # true | false
ALERT_CHANNEL=slack              # slack | email
ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/...
ALERT_EMAIL_TO=alert@example.com

# ⑩ Render / デプロイ補助（必要な場合のみ）
RENDER_SERVICE_NAME=your-service-name
RENDER_ENVIRONMENT=production

# ⑪ 内部・運用専用（非公開）
INTERNAL_DEPLOY_SSH_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----...
