<!DOCTYPE html>
<html lang="ja" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
  <style>
    /* =========================================
       PC Desktop Admin Panel Theme
       デスクトップ専用・管理画面向けレイアウト
       ========================================= */
    :root {
      --pico-font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      --sidebar-width: 260px;
      --sidebar-collapsed-width: 72px;
      --header-height: 60px;
    }

    :root[data-theme="dark"] {
      /* 背景 */
      --pico-background-color: #0f1419;
      --pico-background-color-rgb: 15, 20, 25;

      /* サーフェス（カード・サイドバー） */
      --pico-card-background-color: #1a1f2e;
      --pico-card-sectioning-background-color: #1a1f2e;

      /* ボーダー */
      --pico-border-color: #2d3548;
      --pico-muted-border-color: #2d3548;

      /* テキスト */
      --pico-color: #c9d1d9;
      --pico-muted-color: #8b949e;
      --pico-h1-color: #f0f6fc;
      --pico-h2-color: #e6edf3;
      --pico-h3-color: #c9d1d9;

      /* アクセント（Blue/Indigo - 業務向け） */
      --pico-primary: #58a6ff;
      --pico-primary-hover: #79b8ff;
      --pico-primary-focus: rgba(88, 166, 255, 0.25);
      --pico-primary-inverse: #0d1117;

      /* フォーム */
      --pico-form-element-background-color: #0d1117;
      --pico-form-element-border-color: #30363d;
      --pico-form-element-color: #c9d1d9;
      --pico-form-element-placeholder-color: #6e7681;
      --pico-form-element-active-border-color: #58a6ff;

      /* ボタン */
      --pico-button-background-color: #238636;
      --pico-button-hover-background-color: #2ea043;
      --pico-button-color: #ffffff;

      /* コード */
      --pico-code-background-color: #161b22;
      --pico-code-color: #c9d1d9;

      /* 状態色 */
      --pico-success: #3fb950;
      --pico-warning: #d29922;
      --pico-danger: #f85149;
      --pico-info: #58a6ff;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      min-height: 100vh;
      overflow: hidden;
      font-size: 21px;
    }

    /* =========================================
       Layout Structure
       ========================================= */
    .app-wrapper {
      display: flex;
      height: 100vh;
      overflow: hidden;
    }

    /* Sidebar */
    .sidebar {
      width: var(--sidebar-width);
      background: var(--pico-card-background-color);
      border-right: 1px solid var(--pico-muted-border-color);
      display: flex;
      flex-direction: column;
      transition: width 0.15s ease;
      flex-shrink: 0;
      overflow-y: auto;
      overflow-x: hidden;
    }

    .sidebar.collapsed {
      width: var(--sidebar-collapsed-width);
    }

    .sidebar-header {
      display: flex;
      align-items: center;
      padding: 1rem;
      border-bottom: 1px solid var(--pico-muted-border-color);
      min-height: var(--header-height);
    }

    .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--pico-h1-color);
      font-weight: 600;
      font-size: 1.1rem;
    }

    .sidebar-logo svg {
      width: 32px;
      height: 32px;
      fill: var(--pico-primary);
      flex-shrink: 0;
    }

    .sidebar-logo span {
      white-space: nowrap;
      transition: opacity 0.15s ease;
    }

    .sidebar.collapsed .sidebar-logo span {
      opacity: 0;
      width: 0;
      overflow: hidden;
    }

    .sidebar-nav {
      flex: 1;
      padding: 0.75rem;
    }

    .sidebar-nav > .nav-item {
      margin-bottom: 1rem;
    }

    .nav-section {
      margin-bottom: 1.5rem;
    }

    .nav-section-title {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--pico-muted-color);
      padding: 0 0.75rem;
      margin-bottom: 0.5rem;
      white-space: nowrap;
      transition: opacity 0.15s ease;
    }

    .sidebar.collapsed .nav-section-title {
      opacity: 0;
      height: 0;
      margin: 0;
      overflow: hidden;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.6rem 0.75rem;
      border-radius: 6px;
      color: var(--pico-color);
      text-decoration: none;
      font-size: 1rem;
      transition: all 0.1s ease;
      margin-bottom: 4px;
      white-space: nowrap;
    }

    .nav-item:hover {
      background: rgba(88, 166, 255, 0.1);
      color: var(--pico-h1-color);
    }

    .nav-item.active {
      background: rgba(88, 166, 255, 0.15);
      color: var(--pico-primary);
    }

    .nav-item svg {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      opacity: 0.7;
    }

    .nav-item.active svg {
      opacity: 1;
    }

    .nav-item span {
      transition: opacity 0.15s ease;
    }

    .sidebar.collapsed .nav-item span {
      opacity: 0;
      width: 0;
      overflow: hidden;
    }

    .sidebar-footer {
      padding: 0.75rem;
      border-top: 1px solid var(--pico-muted-border-color);
    }

    .sidebar-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 0.5rem;
      background: transparent;
      border: 1px solid var(--pico-muted-border-color);
      border-radius: 6px;
      color: var(--pico-muted-color);
      cursor: pointer;
      transition: all 0.1s ease;
    }

    .sidebar-toggle:hover {
      background: rgba(88, 166, 255, 0.1);
      color: var(--pico-color);
    }

    .sidebar-toggle svg {
      width: 20px;
      height: 20px;
      transition: transform 0.15s ease;
    }

    .sidebar.collapsed .sidebar-toggle svg {
      transform: rotate(180deg);
    }

    /* Main Content Area */
    .main-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      min-width: 0;
    }

    /* Header */
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
      height: var(--header-height);
      background: var(--pico-card-background-color);
      border-bottom: 1px solid var(--pico-muted-border-color);
      flex-shrink: 0;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .header-title {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--pico-h1-color);
      margin: 0;
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .header-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      background: transparent;
      border: none;
      border-radius: 6px;
      color: var(--pico-muted-color);
      cursor: pointer;
      transition: all 0.1s ease;
    }

    .header-btn:hover {
      background: rgba(88, 166, 255, 0.1);
      color: var(--pico-color);
    }

    .header-btn svg {
      width: 22px;
      height: 22px;
    }

    .user-avatar {
      width: 40px;
      height: 40px;
      border-radius: 6px;
      background: linear-gradient(135deg, var(--pico-primary), #6366f1);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
    }

    /* Main Content */
    .main-content {
      flex: 1;
      overflow-y: auto;
      padding: 1.5rem;
      background: var(--pico-background-color);
    }

    .content-container {
      max-width: 1600px;
      margin: 0 auto;
    }

    /* Cards */
    article {
      background: var(--pico-card-background-color);
      border: 1px solid var(--pico-muted-border-color);
      border-radius: 8px;
      padding: 1.25rem;
      margin-bottom: 1rem;
    }

    /* Data Table Style */
    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 1rem;
    }

    .data-table th,
    .data-table td {
      padding: 0.75rem 1rem;
      text-align: left;
      border-bottom: 1px solid var(--pico-muted-border-color);
    }

    .data-table th {
      background: var(--pico-background-color);
      font-weight: 600;
      color: var(--pico-muted-color);
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .data-table tr:hover {
      background: rgba(88, 166, 255, 0.05);
    }

    /* List Items */
    .list-item {
      background: var(--pico-card-background-color);
      border: 1px solid var(--pico-muted-border-color);
      border-left: 3px solid transparent;
      border-radius: 6px;
      padding: 0.875rem 1rem;
      margin-bottom: 8px;
      transition: all 0.1s ease;
    }

    .list-item:last-child {
      margin-bottom: 0;
    }

    .list-item:hover {
      border-left-color: var(--pico-primary);
      background: rgba(88, 166, 255, 0.03);
    }

    .list-item-content {
      display: flex;
      gap: 1rem;
      align-items: center;
    }

    .list-item-image {
      width: 80px;
      height: 80px;
      object-fit: cover;
      border-radius: 6px;
      border: 1px solid var(--pico-muted-border-color);
      flex-shrink: 0;
    }

    .no-image {
      width: 80px;
      height: 80px;
      background: var(--pico-background-color);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--pico-muted-color);
      font-size: 0.8rem;
      flex-shrink: 0;
    }

    .list-item-info {
      flex: 1;
      min-width: 0;
    }

    .list-item .id {
      font-size: 0.85rem;
      color: var(--pico-muted-color);
      font-family: 'SF Mono', Monaco, Consolas, monospace;
    }

    .list-item .title {
      color: var(--pico-color);
      font-size: 1.1rem;
      font-weight: 500;
    }

    /* Empty State */
    .empty-state {
      padding: 3rem;
      text-align: center;
      color: var(--pico-muted-color);
      font-size: 1rem;
    }

    /* Page Header */
    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
    }

    .page-title {
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--pico-h1-color);
      margin: 0;
    }

    .page-subtitle {
      color: var(--pico-muted-color);
      font-size: 1rem;
      margin-top: 0.25rem;
    }

    /* Breadcrumb */
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1rem;
      color: var(--pico-muted-color);
      margin-bottom: 1rem;
    }

    .breadcrumb a {
      color: var(--pico-muted-color);
      text-decoration: none;
    }

    .breadcrumb a:hover {
      color: var(--pico-primary);
    }

    /* Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.25rem;
    }

    .stat-card {
      background: var(--pico-card-background-color);
      border: 1px solid var(--pico-muted-border-color);
      border-radius: 8px;
      padding: 1.25rem;
    }

    .stat-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.75rem;
    }

    .stat-card-title {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      color: var(--pico-muted-color);
    }

    .stat-card-icon {
      width: 40px;
      height: 40px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .stat-card-icon svg {
      width: 20px;
      height: 20px;
    }

    .stat-card-icon.purple {
      background: rgba(139, 92, 246, 0.2);
      color: #a78bfa;
    }

    .stat-card-icon.blue {
      background: rgba(88, 166, 255, 0.2);
      color: #58a6ff;
    }

    .stat-card-icon.green {
      background: rgba(63, 185, 80, 0.2);
      color: #3fb950;
    }

    .stat-card-icon.amber {
      background: rgba(210, 153, 34, 0.2);
      color: #d29922;
    }

    .stat-card-value {
      font-size: 2rem;
      font-weight: 700;
      color: var(--pico-h1-color);
      margin-bottom: 0.25rem;
    }

    .stat-card-change {
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    .stat-card-change.positive {
      color: var(--pico-success);
    }

    .stat-card-change.negative {
      color: var(--pico-danger);
    }

    /* Form Styles */
    form label {
      font-size: 1rem;
      font-weight: 500;
      color: var(--pico-color);
      margin-bottom: 0.5rem;
    }

    input, select, textarea {
      font-size: 1rem;
      padding: 0.75rem 1rem;
    }

    button, .button {
      font-size: 1rem;
      padding: 0.75rem 1.5rem;
      font-weight: 500;
    }

    /* Button variations */
    .button.small {
      font-size: 0.9rem;
      padding: 0.5rem 1rem;
    }

    .button.outline {
      background: transparent;
      border: 1px solid var(--pico-primary);
      color: var(--pico-primary);
    }

    .button.outline:hover {
      background: rgba(88, 166, 255, 0.1);
    }

    /* Badge */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 0.35rem 0.75rem;
      font-size: 0.9rem;
      font-weight: 500;
      border-radius: 4px;
      background: rgba(88, 166, 255, 0.15);
      color: var(--pico-primary);
    }

    .badge.success {
      background: rgba(63, 185, 80, 0.15);
      color: var(--pico-success);
    }

    .badge.warning {
      background: rgba(210, 153, 34, 0.15);
      color: var(--pico-warning);
    }

    .badge.danger {
      background: rgba(248, 81, 73, 0.15);
      color: var(--pico-danger);
    }

    /* Toolbar */
    .toolbar {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem;
      background: var(--pico-background-color);
      border-radius: 6px;
      margin-bottom: 1rem;
    }

    .toolbar-search {
      flex: 1;
      max-width: 400px;
    }

    .toolbar-search input {
      margin: 0;
      padding: 0.6rem 0.75rem;
      font-size: 1rem;
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: var(--pico-background-color);
    }

    ::-webkit-scrollbar-thumb {
      background: var(--pico-muted-border-color);
      border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: var(--pico-muted-color);
    }

    /* =========================================
       Responsive Design for Non-Mobile Devices
       ========================================= */

    /* Medium screens (tablets, small desktops) */
    @media (max-width: 1200px) {
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    /* Smaller screens (narrow windows, tablets) */
    @media (max-width: 1024px) {
      /* Auto-collapse sidebar */
      .sidebar {
        width: var(--sidebar-collapsed-width);
      }

      .sidebar .sidebar-logo span,
      .sidebar .nav-section-title,
      .sidebar .nav-item span {
        opacity: 0;
        width: 0;
        overflow: hidden;
      }

      .sidebar .nav-section-title {
        height: 0;
        margin: 0;
      }

      .sidebar .sidebar-toggle svg {
        transform: rotate(180deg);
      }

      /* Adjust header */
      .header {
        padding: 0 1rem;
      }

      .header-title {
        font-size: 1.1rem;
      }

      /* Main content padding */
      .main-content {
        padding: 1rem;
      }

      /* Page header stacking */
      .page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
      }

      /* Stats grid to 2 columns */
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      /* Toolbar stacking */
      .toolbar {
        flex-direction: column;
        align-items: stretch;
      }

      .toolbar-search {
        max-width: none;
      }
    }

    /* Narrow screens (still above mobile) */
    @media (max-width: 768px) {
      /* Stats grid to 1 column */
      .stats-grid {
        grid-template-columns: 1fr;
      }

      /* Smaller fonts */
      html, body {
        font-size: 18px;
      }

      .header-title {
        font-size: 1rem;
      }

      .page-title {
        font-size: 1.25rem;
      }

      /* List item content stacking */
      .list-item-content {
        flex-direction: column;
        align-items: flex-start;
      }

      .list-item-image,
      .no-image {
        width: 60px;
        height: 60px;
      }

      /* Adjust card padding */
      article {
        padding: 1rem;
      }

      .stat-card {
        padding: 1rem;
      }

      .stat-card-value {
        font-size: 1.5rem;
      }
    }
  </style>
  <%- typeof head !== 'undefined' ? head : '' %>
  <% if (authConfig?.useAuth) { %>
  <!-- AUTH FEATURE: Clerk JavaScript SDK -->
  <script
    async
    crossorigin="anonymous"
    data-clerk-publishable-key="<%= authConfig.clerkPublishableKey %>"
    src="https://cdn.jsdelivr.net/npm/@clerk/clerk-js@latest/dist/clerk.browser.js"
    type="text/javascript"
  ></script>
  <style>
    /* Clerk UserButton styling */
    .clerk-user-button {
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-btn {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: var(--pico-primary);
      color: var(--pico-primary-inverse);
      border: none;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.1s ease;
    }
    .login-btn:hover {
      background: var(--pico-primary-hover);
    }
    .login-btn svg {
      width: 18px;
      height: 18px;
    }
  </style>
  <% } %>
  <script>
    // API Fetch Helper - LLM_GW_PROJECT_API_KEY 設定時に x-api-key ヘッダを自動付与
    const API_KEY_CONFIG = {
      useApiKey: <%= apiKeyConfig?.useApiKey || false %>,
      apiKey: '<%= apiKeyConfig?.apiKey || "" %>'
    };

    async function apiFetch(url, options = {}) {
      const headers = { ...options.headers };
      if (API_KEY_CONFIG.useApiKey && API_KEY_CONFIG.apiKey) {
        headers['x-api-key'] = API_KEY_CONFIG.apiKey;
      }
      return fetch(url, { ...options, headers });
    }
  </script>
</head>
<body>
  <div class="app-wrapper">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <a href="/dashboard" class="sidebar-logo">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
            <path d="M31.956 14.8C31.372 6.92 25.08.628 17.2.044V5.76a9.04 9.04 0 0 0 9.04 9.04h5.716ZM14.8 26.24v5.716C6.92 31.372.63 25.08.044 17.2H5.76a9.04 9.04 0 0 1 9.04 9.04Zm11.44-9.04h5.716c-.584 7.88-6.876 14.172-14.756 14.756V26.24a9.04 9.04 0 0 1 9.04-9.04ZM.044 14.8C.63 6.92 6.92.628 14.8.044V5.76a9.04 9.04 0 0 1-9.04 9.04H.044Z"/>
          </svg>
          <span>Starter</span>
        </a>
      </div>

      <nav class="sidebar-nav">
        <!-- Dashboard -->
        <a href="/dashboard" class="nav-item<%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? ' active' : '' %>">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          <span>Dashboard</span>
        </a>

        <!-- Microposts -->
        <a href="/dashboard/microposts" class="nav-item<%= typeof activePage !== 'undefined' && activePage === 'microposts' ? ' active' : '' %>">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6.878V6a2.25 2.25 0 0 1 2.25-2.25h7.5A2.25 2.25 0 0 1 18 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 0 0 4.5 9v.878m13.5-3A2.25 2.25 0 0 1 19.5 9v.878m0 0a2.246 2.246 0 0 0-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0 1 21 12v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6c0-.98.626-1.813 1.5-2.122" />
