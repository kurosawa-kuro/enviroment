      <div class="sidebar-footer">
        <button class="sidebar-toggle" id="sidebarToggle" title="Toggle Sidebar">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" />
          </svg>
        </button>
      </div>
    </aside>

    <!-- Main Content Wrapper -->
    <div class="main-wrapper">
      <!-- Header -->
      <header class="header">
        <div class="header-left">
          <h1 class="header-title"><%= typeof pageTitle !== 'undefined' ? pageTitle : title %></h1>
        </div>
        <div class="header-right">
          <button class="header-btn" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
          </button>
          <button class="header-btn" aria-label="Notifications">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
            </svg>
          </button>
          <% if (authConfig?.useAuth) { %>
          <!-- AUTH FEATURE: Clerk UserButton or Login -->
          <div id="clerk-user" class="clerk-user-button">
            <% if (!authConfig.user) { %>
            <a href="/auth/login" class="login-btn">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
              </svg>
              Login
            </a>
            <% } %>
          </div>
          <% } else { %>
          <div class="user-avatar">U</div>
          <% } %>
        </div>
      </header>

      <!-- Main Content -->
      <main class="main-content">
        <div class="content-container">
          <%- body %>
        </div>
      </main>
    </div>
  </div>

  <script>
    // Sidebar Toggle (Desktop only)
    const sidebar = document.getElementById('sidebar');
    const sidebarToggle = document.getElementById('sidebarToggle');

    sidebarToggle?.addEventListener('click', () => {
      sidebar.classList.toggle('collapsed');
      localStorage.setItem('sidebar-collapsed', sidebar.classList.contains('collapsed'));
    });

    // Restore sidebar state
    if (localStorage.getItem('sidebar-collapsed') === 'true') {
      sidebar.classList.add('collapsed');
    }
  </script>
  <% if (authConfig?.useAuth) { %>
  <!-- AUTH FEATURE: Clerk initialization -->
  <script>
    window.addEventListener('load', async () => {
      if (window.Clerk) {
        try {
          await window.Clerk.load();
          const userEl = document.getElementById('clerk-user');
          if (userEl && window.Clerk.user) {
            // ログイン済み: UserButtonを表示
            userEl.innerHTML = '';
            window.Clerk.mountUserButton(userEl, {
              appearance: {
                elements: {
                  avatarBox: { width: '40px', height: '40px' }
                }
              }
            });
          }
        } catch (e) {
          console.error('Clerk initialization error:', e);
        }
      }
    });
  </script>
  <% } %>
  <%- typeof scripts !== 'undefined' ? scripts : '' %>
</body>
</html>
