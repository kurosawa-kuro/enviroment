<!-- Breadcrumb -->
<nav class="breadcrumb">
  <a href="/dashboard">Dashboard</a>
  <span>/</span>
  <span>Microposts</span>
</nav>

<!-- Page Header -->
<div class="page-header">
  <div>
    <h2 class="page-title">Microposts</h2>
  </div>
  <div style="display: flex; gap: 0.5rem; align-items: center;">
    <!-- Filter Dropdown -->
    <select id="statusFilter" style="width: auto; margin: 0; padding: 0.4rem 0.8rem; font-size: 0.9rem;">
      <option value="">All Status</option>
      <option value="draft">Draft</option>
      <option value="published">Published</option>
    </select>
    <a href="/dashboard/microposts/new" class="button small">+ New</a>
  </div>
</div>

<!-- Data Container -->
<article style="padding: 0; overflow: hidden;">
  <div style="display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.25rem; border-bottom: 1px solid var(--pico-muted-border-color);">
    <span style="font-size: 1rem; font-weight: 500;">All Records</span>
    <span id="micropost-count" class="badge">-</span>
  </div>
  <!-- List View -->
  <div id="micropost-list">
    <div class="empty-state" aria-busy="true">Loading...</div>
  </div>
</article>

<style>
  .micropost-table {
    width: 100%;
    border-collapse: collapse;
  }
  .micropost-table th,
  .micropost-table td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--pico-muted-border-color);
    font-size: 1rem;
  }
  .micropost-table th {
    background: var(--pico-background-color);
    font-weight: 600;
    color: var(--pico-muted-color);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    position: sticky;
    top: 0;
  }
  .micropost-table tbody tr {
    cursor: pointer;
    transition: background 0.1s ease;
  }
  .micropost-table tbody tr:hover {
    background: rgba(88, 166, 255, 0.05);
  }
  .micropost-table .thumb {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--pico-muted-border-color);
  }
  .micropost-table .no-thumb {
    width: 80px;
    height: 80px;
    background: var(--pico-background-color);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--pico-muted-color);
    font-size: 0.9rem;
  }
  .micropost-table .id-cell {
    font-family: 'SF Mono', Monaco, Consolas, monospace;
    font-size: 0.85rem;
    color: var(--pico-muted-color);
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .micropost-table .title-cell {
    font-weight: 500;
    font-size: 1.1rem;
  }
  .micropost-table .body-cell {
    font-size: 0.9rem;
    color: var(--pico-muted-color);
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .micropost-table .status-cell {
    font-size: 0.85rem;
  }
  .status-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 500;
  }
  .status-badge.draft {
    background: rgba(255, 193, 7, 0.2);
    color: #ffc107;
  }
  .status-badge.published {
    background: rgba(40, 167, 69, 0.2);
    color: #28a745;
  }
  .micropost-table .date-cell {
    font-size: 0.85rem;
    color: var(--pico-muted-color);
    white-space: nowrap;
  }
  .micropost-table .action-cell {
    width: 80px;
    text-align: center;
  }
  .micropost-table .action-link {
    color: var(--pico-primary);
    text-decoration: none;
    font-size: 1rem;
    padding: 0.5rem 1rem;
    border-radius: 6px;
  }
  .micropost-table .action-link:hover {
    background: rgba(88, 166, 255, 0.1);
  }
</style>

<script>
  const API_URL = '/dashboard/microposts/api';
  let micropostsData = [];

  function escapeHtml(str) {
    if (str == null) return '';
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderListView(microposts) {
    const listEl = document.getElementById('micropost-list');

    if (microposts.length === 0) {
      listEl.innerHTML = `
        <div class="empty-state">
          <p style="margin: 0; font-size: 1rem;">No records found</p>
          <p style="margin: 0.5rem 0 0 0; font-size: 1rem;">
            <a href="/dashboard/microposts/new">Create first record</a>
          </p>
        </div>
      `;
      return;
    }

    let html = `
      <table class="micropost-table">
        <thead>
          <tr>
            <th style="width: 100px;">Image</th>
            <th style="width: 120px;">ID</th>
            <th>Title</th>
            <th>Body</th>
            <th style="width: 100px;">Status</th>
            <th style="width: 100px;">Created</th>
            <th class="action-cell">Action</th>
          </tr>
        </thead>
        <tbody>
    `;

    microposts.forEach(post => {
      const thumbHtml = post.imagePath
        ? '<img src="' + escapeHtml(post.imagePath) + '" alt="" class="thumb">'
        : '<div class="no-thumb">-</div>';

      const dateStr = post.createdAt
        ? new Date(post.createdAt).toLocaleDateString('ja-JP', { month: 'short', day: 'numeric' })
        : '-';

      const shortId = post.id.length > 12 ? post.id.slice(-12) : post.id;
      const shortBody = post.body.length > 50 ? post.body.slice(0, 50) + '...' : post.body;

      html += `
        <tr onclick="location.href='/dashboard/microposts/${escapeHtml(post.id)}'">
          <td>${thumbHtml}</td>
          <td class="id-cell" title="${escapeHtml(post.id)}">${escapeHtml(shortId)}</td>
          <td class="title-cell">${escapeHtml(post.title)}</td>
          <td class="body-cell" title="${escapeHtml(post.body)}">${escapeHtml(shortBody)}</td>
          <td class="status-cell"><span class="status-badge ${escapeHtml(post.status)}">${escapeHtml(post.status)}</span></td>
          <td class="date-cell">${dateStr}</td>
          <td class="action-cell">
            <a href="/dashboard/microposts/${escapeHtml(post.id)}" class="action-link" onclick="event.stopPropagation()">View</a>
          </td>
        </tr>
      `;
    });

    html += '</tbody></table>';
    listEl.innerHTML = html;
  }

  async function loadMicroposts() {
    const listEl = document.getElementById('micropost-list');
    const countEl = document.getElementById('micropost-count');
    const statusFilter = document.getElementById('statusFilter').value;

    let url = API_URL;
    if (statusFilter) {
      url += '?status=' + encodeURIComponent(statusFilter);
    }

    try {
      const res = await apiFetch(url);
      const data = await res.json();

      if (data.error) {
        listEl.innerHTML = '<div class="empty-state">' + escapeHtml(data.error) + '</div>';
        countEl.textContent = '0';
        return;
      }

      micropostsData = data.data?.microposts || [];
      countEl.textContent = micropostsData.length;

      renderListView(micropostsData);

    } catch (err) {
      console.error('Failed to load microposts:', err);
      listEl.innerHTML = '<div class="empty-state">Failed to load data</div>';
      countEl.textContent = 'Error';
    }
  }

  // Initialize
  document.getElementById('statusFilter').addEventListener('change', loadMicroposts);
  loadMicroposts();
</script>
