{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "doppler run -- npx tsx watch src/index.ts",
    "build": "tsc && cp -r src/presentation/views dist/src/presentation/ && mkdir -p dist/env && cp env/config.yaml dist/env/",
    "start": "doppler run -- node dist/src/index.js",
    "test": "dotenv -e .env.test -- npx vitest run",
    "test:watch": "dotenv -e .env.test -- npx vitest",
    "test:e2e": "doppler run -- npx playwright test",
    "test:e2e:ui": "doppler run -- npx playwright test --ui",
    "test:e2e:headed": "doppler run -- npx playwright test --headed"
  },
  "dependencies": {
    "@clerk/backend": "^2.29.0",
    "js-yaml": "^4.1.0",
    "@hono/clerk-auth": "^3.0.3",
    "@hono/node-server": "^1.17.1",
    "@upstash/redis": "^1.36.0",
    "awilix": "^12.0.5",
    "cloudinary": "^2.8.0",
    "ejs": "^3.1.10",
    "hono": "^4.8.7",
    "hono-rate-limiter": "^0.5.0",
    "mongodb": "^7.0.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/ejs": "^3.1.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.17",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.15"
  }
}
