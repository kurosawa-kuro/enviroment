#!/bin/bash
# Cache Management Script
# Generated by Ansible - do not edit manually

CACHE_DIR="{{ download_dir }}/cache"
RETENTION_DAYS="{{ performance_settings.cache_retention_days | default(30) }}"
LOG_FILE="/var/log/cache_manager.log"

# Logging function
log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

# Cache cleanup function
cleanup_cache() {
    log "Starting cache cleanup process"
    
    # Clean old files
    if [ -d "$CACHE_DIR" ]; then
        find "$CACHE_DIR" -type f -mtime +$RETENTION_DAYS -delete
        log "Removed files older than $RETENTION_DAYS days"
        
        # Clean empty directories
        find "$CACHE_DIR" -type d -empty -delete
        log "Removed empty directories"
    fi
    
    # APT cache cleanup
    apt-get autoclean
    log "APT cache cleaned"
    
    # Show cache statistics
    show_stats
}

# Cache statistics function
show_stats() {
    log "=== Cache Statistics ==="
    
    if [ -d "$CACHE_DIR" ]; then
        # Total cache size
        TOTAL_SIZE=$(du -sh "$CACHE_DIR" 2>/dev/null | cut -f1)
        log "Total cache size: $TOTAL_SIZE"
        
        # File count by type
        log "Files by type:"
        find "$CACHE_DIR" -type f -name "*.deb" | wc -l | xargs echo "  .deb files:"
        find "$CACHE_DIR" -type f -name "*.tar.gz" | wc -l | xargs echo "  .tar.gz files:"
        find "$CACHE_DIR" -type f -name "*.zip" | wc -l | xargs echo "  .zip files:"
        
        # Directory sizes
        for dir in apt downloads builds pip npm maven gradle; do
            if [ -d "$CACHE_DIR/$dir" ]; then
                SIZE=$(du -sh "$CACHE_DIR/$dir" 2>/dev/null | cut -f1)
                log "  $dir cache: $SIZE"
            fi
        done
    else
        log "Cache directory does not exist: $CACHE_DIR"
    fi
    
    log "=== End Statistics ==="
}

# Cache optimization function
optimize_cache() {
    log "Starting cache optimization"
    
    # Remove duplicate files
    if command -v fdupes >/dev/null 2>&1; then
        fdupes -rdN "$CACHE_DIR" 2>/dev/null
        log "Removed duplicate files"
    fi
    
    # Compress old log files
    find /var/log -name "*.log" -mtime +7 -exec gzip {} \;
    log "Compressed old log files"
    
    show_stats
}

# Initialize cache function
init_cache() {
    log "Initializing cache directories"
    
    mkdir -p "$CACHE_DIR"/{apt,downloads,builds,pip,npm,maven,gradle}
    chown -R {{ ansible_user_id }}:{{ ansible_user_gid }} "$CACHE_DIR"
    chmod -R 755 "$CACHE_DIR"
    
    log "Cache directories initialized"
    show_stats
}

# Main script logic
case "$1" in
    cleanup)
        cleanup_cache
        ;;
    stats)
        show_stats
        ;;
    optimize)
        optimize_cache
        ;;
    init)
        init_cache
        ;;
    *)
        echo "Usage: $0 {cleanup|stats|optimize|init}"
        echo "  cleanup  - Remove old cached files"
        echo "  stats    - Show cache statistics"
        echo "  optimize - Optimize cache storage"
        echo "  init     - Initialize cache directories"
        exit 1
        ;;
esac

exit 0