# APT Cache Configuration
# Generated by Ansible - do not edit manually

# Cache directory for downloaded packages
Dir::Cache::Archives "{{ download_dir }}/cache/apt";

# Keep downloaded packages
APT::Keep-Downloaded-Packages "true";

# Cache settings
APT::Cache-Start "32505856";
APT::Cache-Grow "2097152";
APT::Cache-Limit "134217728";

# Network timeouts for better reliability
Acquire::http::Timeout "30";
Acquire::https::Timeout "30";
Acquire::ftp::Timeout "30";

# Retry configuration
Acquire::Retries "3";

# Parallel downloads for faster package acquisition
APT::Acquire::Max-Default-Sec "10";
Binary::apt::APT::Keep-Downloaded-Packages "true";