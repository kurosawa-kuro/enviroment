# Cache Environment Variables
# Generated by Ansible - do not edit manually

export ANSIBLE_CACHE_DIR="{{ download_dir }}/cache"

# APT cache
export APT_CACHE_DIR="{{ download_dir }}/cache/apt"

# Development tools cache
export PIP_CACHE_DIR="{{ download_dir }}/cache/pip"
export NPM_CONFIG_CACHE="{{ download_dir }}/cache/npm"
export MAVEN_OPTS="-Dmaven.repo.local={{ download_dir }}/cache/maven"
export GRADLE_USER_HOME="{{ download_dir }}/cache/gradle"

# Download cache
export DOWNLOAD_CACHE_DIR="{{ download_dir }}/cache/downloads"

# Cache configuration
export CACHE_RETENTION_DAYS="{{ performance_settings.cache_retention_days | default(30) }}"
export ENABLE_CACHE="{{ performance_settings.enable_cache | default(true) }}"