<!-- Page Header -->
<div class="page-header">
  <div>
    <h2 class="page-title">Processing Reservation Status</h2>
    <p class="page-subtitle">Monitor processing status with real-time polling</p>
  </div>
  <button class="button" onclick="createReservation()">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 20px; height: 20px; margin-right: 0.5rem;">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    New Reservation
  </button>
</div>

<!-- Stats Grid -->
<div class="stats-grid stats-grid-4">
  <div class="stat-card">
    <div class="stat-card-header">
      <div class="stat-card-title">Total</div>
      <div class="stat-card-icon blue">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M5.566 4.657A4.505 4.505 0 016.75 4.5h10.5c.41 0 .806.055 1.183.157A3 3 0 0015.75 3h-7.5a3 3 0 00-2.684 1.657zM2.25 12a3 3 0 013-3h13.5a3 3 0 013 3v6a3 3 0 01-3 3H5.25a3 3 0 01-3-3v-6zM5.25 7.5c-.41 0-.806.055-1.184.157A3 3 0 016.75 6h10.5a3 3 0 012.683 1.657A4.505 4.505 0 0018.75 7.5H5.25z"/>
        </svg>
      </div>
    </div>
    <div class="stat-card-value" id="stat-total">0</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-header">
      <div class="stat-card-title">Pending</div>
      <div class="stat-card-icon amber">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z" clip-rule="evenodd"/>
        </svg>
      </div>
    </div>
    <div class="stat-card-value" id="stat-pending">0</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-header">
      <div class="stat-card-title">Processing</div>
      <div class="stat-card-icon purple">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path fill-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0112.548-3.364l1.903 1.903h-3.183a.75.75 0 000 1.5h4.992a.75.75 0 00.75-.75V4.356a.75.75 0 00-1.5 0v3.18l-1.9-1.9A9 9 0 003.306 9.67a.75.75 0 101.45.388zm15.408 3.352a.75.75 0 00-.919.53 7.5 7.5 0 01-12.548 3.364l-1.902-1.903h3.183a.75.75 0 000-1.5H2.984a.75.75 0 00-.75.75v4.992a.75.75 0 001.5 0v-3.18l1.9 1.9a9 9 0 0015.059-4.035.75.75 0 00-.53-.918z" clip-rule="evenodd"/>
        </svg>
      </div>
    </div>
    <div class="stat-card-value" id="stat-processing">0</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-header">
      <div class="stat-card-title">Completed</div>
      <div class="stat-card-icon green">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/>
        </svg>
      </div>
    </div>
    <div class="stat-card-value" id="stat-completed">0</div>
  </div>
</div>

<!-- Polling Control -->
<div class="polling-control">
  <div class="polling-status">
    <span class="polling-indicator" id="polling-indicator"></span>
    <span id="polling-text">Polling: Active (1s interval)</span>
  </div>
  <div class="polling-actions">
    <button class="button small outline" onclick="togglePolling()" id="polling-toggle">Pause</button>
    <button class="button small outline" onclick="clearAllReservations()">Clear All</button>
  </div>
</div>

<!-- Reservations List -->
<article>
  <div class="section-label">Reservations</div>
  <div id="reservations-list">
    <div class="empty-state">No reservations yet. Click "New Reservation" to create one.</div>
  </div>
</article>

<p style="margin-top: 1.5rem; color: var(--pico-muted-color); font-size: 0.9rem;">
  Last updated: <span id="last-updated"><%= timestamp %></span>
</p>

<style>
  .stats-grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .polling-control {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: var(--pico-card-background-color);
    border: 1px solid var(--pico-muted-border-color);
    border-radius: 8px;
    margin-bottom: 1rem;
  }

  .polling-status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .polling-indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--pico-success);
    animation: pulse 1.5s infinite;
  }

  .polling-indicator.paused {
    background: var(--pico-muted-color);
    animation: none;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .polling-actions {
    display: flex;
    gap: 0.5rem;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--pico-muted-color);
    margin-bottom: 0.75rem;
  }

  .reservation-item {
    display: flex;
    align-items: center;
    padding: 1rem;
    background: var(--pico-background-color);
    border: 1px solid var(--pico-muted-border-color);
    border-radius: 8px;
    margin-bottom: 0.5rem;
    gap: 1rem;
  }

  .reservation-item:last-child {
    margin-bottom: 0;
  }

  .reservation-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .reservation-icon svg {
    width: 20px;
    height: 20px;
  }

  .reservation-icon.pending {
    background: rgba(210, 153, 34, 0.2);
    color: var(--pico-warning);
  }

  .reservation-icon.processing {
    background: rgba(139, 92, 246, 0.2);
    color: #a78bfa;
  }

  .reservation-icon.completed {
    background: rgba(63, 185, 80, 0.2);
    color: var(--pico-success);
  }

  .reservation-icon.failed {
    background: rgba(248, 81, 73, 0.2);
    color: var(--pico-danger);
  }

  .reservation-info {
    flex: 1;
    min-width: 0;
  }

  .reservation-name {
    font-weight: 500;
    color: var(--pico-color);
    margin-bottom: 0.25rem;
  }

  .reservation-id {
    font-size: 0.85rem;
    color: var(--pico-muted-color);
    font-family: 'SF Mono', Monaco, Consolas, monospace;
  }

  .reservation-progress {
    flex: 1;
    max-width: 200px;
  }

  .progress-bar {
    height: 8px;
    background: var(--pico-muted-border-color);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 0.25rem;
  }

  .progress-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.3s ease;
  }

  .progress-fill.pending {
    background: var(--pico-warning);
  }

  .progress-fill.processing {
    background: linear-gradient(90deg, #a78bfa, #8b5cf6);
  }

  .progress-fill.completed {
    background: var(--pico-success);
  }

  .progress-fill.failed {
    background: var(--pico-danger);
  }

  .progress-text {
    font-size: 0.8rem;
    color: var(--pico-muted-color);
    text-align: right;
  }

  .reservation-status {
    min-width: 100px;
    text-align: center;
  }

  .reservation-actions {
    display: flex;
    gap: 0.5rem;
  }

  .icon-btn {
    padding: 0.5rem;
    background: transparent;
    border: 1px solid var(--pico-muted-border-color);
    border-radius: 6px;
    color: var(--pico-muted-color);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .icon-btn:hover {
    background: rgba(248, 81, 73, 0.1);
    border-color: var(--pico-danger);
    color: var(--pico-danger);
  }

  .icon-btn svg {
    width: 16px;
    height: 16px;
  }

  .empty-state {
    padding: 3rem;
    text-align: center;
    color: var(--pico-muted-color);
    font-size: 1rem;
  }

  /* Processing animation */
  .reservation-icon.processing svg {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Responsive Design */
  @media (max-width: 1200px) {
    .stats-grid-4 {
      grid-template-columns: repeat(2, 1fr);
    }

    .reservation-progress {
      max-width: 150px;
    }
  }

  @media (max-width: 1024px) {
    .polling-control {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .polling-actions {
      width: 100%;
    }

    .polling-actions button {
      flex: 1;
    }
  }

  @media (max-width: 768px) {
    .stats-grid-4 {
      grid-template-columns: 1fr;
    }

    .reservation-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .reservation-icon {
      align-self: flex-start;
    }

    .reservation-info {
      width: 100%;
    }

    .reservation-progress {
      width: 100%;
      max-width: none;
    }

    .reservation-status {
      width: 100%;
      text-align: left;
    }

    .reservation-actions {
      width: 100%;
      justify-content: flex-end;
    }
  }
</style>

<script>
  let pollingInterval = null;
  let isPolling = true;
  const POLLING_INTERVAL = 1000; // 1秒

  // ページ読み込み時に開始
  document.addEventListener('DOMContentLoaded', () => {
    startPolling();
  });

  function startPolling() {
    if (pollingInterval) return;
    pollingInterval = setInterval(fetchReservations, POLLING_INTERVAL);
    fetchReservations(); // 即座に1回実行
  }

  function stopPolling() {
    if (pollingInterval) {
      clearInterval(pollingInterval);
      pollingInterval = null;
    }
  }

  function togglePolling() {
    isPolling = !isPolling;
    const indicator = document.getElementById('polling-indicator');
    const text = document.getElementById('polling-text');
    const btn = document.getElementById('polling-toggle');

    if (isPolling) {
      startPolling();
      indicator.classList.remove('paused');
      text.textContent = 'Polling: Active (1s interval)';
      btn.textContent = 'Pause';
    } else {
      stopPolling();
      indicator.classList.add('paused');
      text.textContent = 'Polling: Paused';
      btn.textContent = 'Resume';
    }
  }

  async function fetchReservations() {
    try {
      const res = await apiFetch('/system/jobs/api');
      const data = await res.json();

      if (data.success) {
        renderReservations(data.data);
        updateStats(data.data);
        document.getElementById('last-updated').textContent = new Date().toLocaleString('ja-JP');
      }
    } catch (err) {
      console.error('Failed to fetch reservations:', err);
    }
  }

  function renderReservations(reservations) {
    const container = document.getElementById('reservations-list');

    if (reservations.length === 0) {
      container.innerHTML = '<div class="empty-state">No reservations yet. Click "New Reservation" to create one.</div>';
      return;
    }

    container.innerHTML = reservations.map(r => `
      <div class="reservation-item" data-id="${r.id}">
        <div class="reservation-icon ${r.status}">
          ${getStatusIcon(r.status)}
        </div>
        <div class="reservation-info">
          <div class="reservation-name">${escapeHtml(r.name)}</div>
          <div class="reservation-id">${r.id}</div>
        </div>
        <div class="reservation-progress">
          <div class="progress-bar">
            <div class="progress-fill ${r.status}" style="width: ${r.progress}%"></div>
          </div>
          <div class="progress-text">${r.progress}%</div>
        </div>
        <div class="reservation-status">
          <span class="badge ${getStatusBadgeClass(r.status)}">${r.status.toUpperCase()}</span>
        </div>
        <div class="reservation-actions">
          <button class="icon-btn" onclick="deleteReservation('${r.id}')" title="Delete">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
          </button>
        </div>
      </div>
    `).join('');
  }

  function getStatusIcon(status) {
    switch (status) {
      case 'pending':
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z" clip-rule="evenodd"/>
        </svg>`;
      case 'processing':
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path fill-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0112.548-3.364l1.903 1.903h-3.183a.75.75 0 000 1.5h4.992a.75.75 0 00.75-.75V4.356a.75.75 0 00-1.5 0v3.18l-1.9-1.9A9 9 0 003.306 9.67a.75.75 0 101.45.388zm15.408 3.352a.75.75 0 00-.919.53 7.5 7.5 0 01-12.548 3.364l-1.902-1.903h3.183a.75.75 0 000-1.5H2.984a.75.75 0 00-.75.75v4.992a.75.75 0 001.5 0v-3.18l1.9 1.9a9 9 0 0015.059-4.035.75.75 0 00-.53-.918z" clip-rule="evenodd"/>
        </svg>`;
      case 'completed':
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/>
        </svg>`;
      case 'failed':
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zm-1.72 6.97a.75.75 0 10-1.06 1.06L10.94 12l-1.72 1.72a.75.75 0 101.06 1.06L12 13.06l1.72 1.72a.75.75 0 101.06-1.06L13.06 12l1.72-1.72a.75.75 0 10-1.06-1.06L12 10.94l-1.72-1.72z" clip-rule="evenodd"/>
        </svg>`;
      default:
        return '';
    }
  }

  function getStatusBadgeClass(status) {
    switch (status) {
      case 'pending': return 'warning';
      case 'processing': return '';
      case 'completed': return 'success';
      case 'failed': return 'danger';
      default: return '';
    }
  }

  function updateStats(reservations) {
    const stats = {
      total: reservations.length,
      pending: reservations.filter(r => r.status === 'pending').length,
      processing: reservations.filter(r => r.status === 'processing').length,
      completed: reservations.filter(r => r.status === 'completed').length
    };

    document.getElementById('stat-total').textContent = stats.total;
    document.getElementById('stat-pending').textContent = stats.pending;
    document.getElementById('stat-processing').textContent = stats.processing;
    document.getElementById('stat-completed').textContent = stats.completed;
  }

  async function createReservation() {
    try {
      const res = await apiFetch('/system/jobs/api', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: `Task ${new Date().toLocaleTimeString('ja-JP')}` })
      });
      const data = await res.json();
      if (data.success) {
        fetchReservations();
      }
    } catch (err) {
      console.error('Failed to create reservation:', err);
    }
  }

  async function deleteReservation(id) {
    try {
      await apiFetch(`/system/jobs/api/${id}`, { method: 'DELETE' });
      fetchReservations();
    } catch (err) {
      console.error('Failed to delete reservation:', err);
    }
  }

  async function clearAllReservations() {
    if (!confirm('Are you sure you want to clear all reservations?')) return;
    try {
      const res = await apiFetch('/system/jobs/api');
      const data = await res.json();
      if (data.success) {
        await Promise.all(data.data.map(r =>
          apiFetch(`/system/jobs/api/${r.id}`, { method: 'DELETE' })
        ));
        fetchReservations();
      }
    } catch (err) {
      console.error('Failed to clear reservations:', err);
    }
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
</script>
