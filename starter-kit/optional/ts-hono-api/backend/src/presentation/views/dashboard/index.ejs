<!-- Section: System Status (見る) -->
<div class="section-label">System Status</div>
<div class="stats-grid stats-grid-3">
  <div class="stat-card">
    <div class="stat-card-header">
      <div class="stat-card-title">API Status</div>
      <div class="stat-card-icon green">
        <!-- Heroicons: check-circle (solid) -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
        </svg>
      </div>
    </div>
    <div class="stat-card-value" style="color: var(--pico-success);">Online</div>
    <div class="stat-card-change positive">Operational</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-header">
      <div class="stat-card-title">Database</div>
      <div class="stat-card-icon purple">
        <!-- Heroicons: circle-stack (solid) -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M21 6.375c0 2.692-4.03 4.875-9 4.875S3 9.067 3 6.375 7.03 1.5 12 1.5s9 2.183 9 4.875Z" />
          <path d="M12 12.75c2.685 0 5.19-.586 7.078-1.609a8.283 8.283 0 0 0 1.897-1.384c.016.121.025.244.025.368C21 12.817 16.97 15 12 15s-9-2.183-9-4.875c0-.124.009-.247.025-.368a8.285 8.285 0 0 0 1.897 1.384C6.809 12.164 9.315 12.75 12 12.75Z" />
          <path d="M12 16.5c2.685 0 5.19-.586 7.078-1.609a8.282 8.282 0 0 0 1.897-1.384c.016.121.025.244.025.368 0 2.692-4.03 4.875-9 4.875s-9-2.183-9-4.875c0-.124.009-.247.025-.368a8.284 8.284 0 0 0 1.897 1.384C6.809 15.914 9.315 16.5 12 16.5Z" />
          <path d="M12 20.25c2.685 0 5.19-.586 7.078-1.609a8.282 8.282 0 0 0 1.897-1.384c.016.121.025.244.025.368 0 2.692-4.03 4.875-9 4.875s-9-2.183-9-4.875c0-.124.009-.247.025-.368a8.284 8.284 0 0 0 1.897 1.384C6.809 19.664 9.315 20.25 12 20.25Z" />
        </svg>
      </div>
    </div>
    <div class="stat-card-value" style="font-size: 1.25rem;"><%= config.dbType %></div>
    <div class="stat-card-change"><%= config.mongoDbName %></div>
  </div>

  <div class="stat-card">
    <div class="stat-card-header">
      <div class="stat-card-title">Environment</div>
      <div class="stat-card-icon amber">
        <!-- Heroicons: adjustments-horizontal (solid) -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.75 12.75h1.5a.75.75 0 0 0 0-1.5h-1.5a.75.75 0 0 0 0 1.5ZM12 6a.75.75 0 0 1 .75-.75h7.5a.75.75 0 0 1 0 1.5h-7.5A.75.75 0 0 1 12 6ZM12 18a.75.75 0 0 1 .75-.75h7.5a.75.75 0 0 1 0 1.5h-7.5A.75.75 0 0 1 12 18ZM3.75 6.75h1.5a.75.75 0 1 0 0-1.5h-1.5a.75.75 0 0 0 0 1.5ZM5.25 18.75h-1.5a.75.75 0 0 1 0-1.5h1.5a.75.75 0 0 1 0 1.5ZM3 12a.75.75 0 0 1 .75-.75h7.5a.75.75 0 0 1 0 1.5h-7.5A.75.75 0 0 1 3 12ZM9 3.75a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5ZM12.75 12a2.25 2.25 0 1 1 4.5 0 2.25 2.25 0 0 1-4.5 0ZM9 15.75a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5Z" />
        </svg>
      </div>
    </div>
    <div class="stat-card-value" style="font-size: 1.25rem; color: <%= config.env === 'production' ? 'var(--pico-danger)' : 'var(--pico-success)' %>;"><%= config.env %></div>
    <div class="stat-card-change">Port <%= config.port %></div>
  </div>
</div>

<!-- Section: Data Summary (判断) -->
<div class="section-label">Data Summary</div>
<div class="stats-grid stats-grid-3">
  <div class="stat-card">
    <div class="stat-card-header">
      <div class="stat-card-title">Total Microposts</div>
      <div class="stat-card-icon blue">
        <!-- Heroicons: rectangle-stack (solid) -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M5.566 4.657A4.505 4.505 0 0 1 6.75 4.5h10.5c.41 0 .806.055 1.183.157A3 3 0 0 0 15.75 3h-7.5a3 3 0 0 0-2.684 1.657ZM2.25 12a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3v-6ZM5.25 7.5c-.41 0-.806.055-1.184.157A3 3 0 0 1 6.75 6h10.5a3 3 0 0 1 2.683 1.657A4.505 4.505 0 0 0 18.75 7.5H5.25Z" />
        </svg>
      </div>
    </div>
    <div class="stat-card-value" id="total-microposts">-</div>
    <div class="stat-card-change positive">Records</div>
  </div>

  <div class="stat-card placeholder">
    <div class="stat-card-header">
      <div class="stat-card-title">Total Resources</div>
      <div class="stat-card-icon" style="opacity: 0.3;">
        <!-- Heroicons: folder (solid) -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19.5 21a3 3 0 0 0 3-3v-4.5a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3V18a3 3 0 0 0 3 3h15ZM1.5 10.146V6a3 3 0 0 1 3-3h5.379a2.25 2.25 0 0 1 1.59.659l2.122 2.121c.14.141.331.22.53.22H19.5a3 3 0 0 1 3 3v1.146A4.483 4.483 0 0 0 19.5 9h-15a4.483 4.483 0 0 0-3 1.146Z" />
        </svg>
      </div>
    </div>
    <div class="stat-card-value placeholder-value">-</div>
    <div class="stat-card-change">Coming soon</div>
  </div>

  <div class="stat-card placeholder">
    <div class="stat-card-header">
      <div class="stat-card-title">Total Storage</div>
      <div class="stat-card-icon" style="opacity: 0.3;">
        <!-- Heroicons: server (solid) -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M4.08 5.227A3 3 0 0 1 6.979 3H17.02a3 3 0 0 1 2.9 2.227l2.113 7.926A5.228 5.228 0 0 0 18.75 12H5.25a5.228 5.228 0 0 0-3.284 1.153L4.08 5.227Z" />
          <path fill-rule="evenodd" d="M5.25 13.5a3.75 3.75 0 1 0 0 7.5h13.5a3.75 3.75 0 1 0 0-7.5H5.25Zm10.5 4.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm3.75-.75a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" clip-rule="evenodd" />
        </svg>
      </div>
    </div>
    <div class="stat-card-value placeholder-value">-</div>
    <div class="stat-card-change">Coming soon</div>
  </div>
</div>

<!-- Section: Quick Actions (行動) -->
<div class="section-label">Quick Actions</div>
<div class="action-grid-full">
  <a href="/dashboard/microposts" class="action-item">
    <!-- Heroicons: rectangle-stack (solid) -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="var(--pico-primary)">
      <path d="M5.566 4.657A4.505 4.505 0 0 1 6.75 4.5h10.5c.41 0 .806.055 1.183.157A3 3 0 0 0 15.75 3h-7.5a3 3 0 0 0-2.684 1.657ZM2.25 12a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3v-6ZM5.25 7.5c-.41 0-.806.055-1.184.157A3 3 0 0 1 6.75 6h10.5a3 3 0 0 1 2.683 1.657A4.505 4.505 0 0 0 18.75 7.5H5.25Z" />
    </svg>
    <span>View Microposts</span>
  </a>
  <a href="/dashboard/microposts/new" class="action-item">
    <!-- Heroicons: plus-circle (solid) -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="var(--pico-success)">
      <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM12.75 9a.75.75 0 0 0-1.5 0v2.25H9a.75.75 0 0 0 0 1.5h2.25V15a.75.75 0 0 0 1.5 0v-2.25H15a.75.75 0 0 0 0-1.5h-2.25V9Z" clip-rule="evenodd" />
    </svg>
    <span>Create Micropost</span>
  </a>
  <a href="/dashboard/microposts/api" target="_blank" class="action-item">
    <!-- Heroicons: command-line (solid) -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="var(--pico-info)">
      <path fill-rule="evenodd" d="M2.25 6a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3v12a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V6Zm3.97.97a.75.75 0 0 1 1.06 0l2.25 2.25a.75.75 0 0 1 0 1.06l-2.25 2.25a.75.75 0 0 1-1.06-1.06l1.72-1.72-1.72-1.72a.75.75 0 0 1 0-1.06Zm4.28 4.28a.75.75 0 0 0 0 1.5h3a.75.75 0 0 0 0-1.5h-3Z" clip-rule="evenodd" />
    </svg>
    <span>API Endpoint</span>
  </a>
  <a href="/api/health" target="_blank" class="action-item">
    <!-- Heroicons: heart (solid) -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="var(--pico-warning)">
      <path d="m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
    </svg>
    <span>Health Check</span>
  </a>
</div>

<style>
  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--pico-muted-color);
    margin-bottom: 0.75rem;
    margin-top: 0.5rem;
  }

  .section-label:first-child {
    margin-top: 0;
  }

  .stats-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .stat-card.placeholder {
    opacity: 0.5;
    border-style: dashed;
  }

  .stat-card.placeholder .placeholder-value {
    color: var(--pico-muted-color);
  }

  .action-grid-full {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .action-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--pico-card-background-color);
    border: 1px solid var(--pico-muted-border-color);
    border-radius: 8px;
    text-decoration: none;
    color: var(--pico-color);
    font-size: 1rem;
    font-weight: 500;
    transition: all 0.15s ease;
  }

  .action-item:hover {
    background: rgba(88, 166, 255, 0.08);
    border-color: var(--pico-primary);
    transform: translateY(-1px);
  }

  .action-item svg {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  /* Responsive Design */
  @media (max-width: 1200px) {
    .stats-grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }

    .action-grid-full {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .stats-grid-3 {
      grid-template-columns: 1fr;
    }

    .action-grid-full {
      grid-template-columns: 1fr;
    }

    .action-item {
      padding: 0.875rem 1rem;
    }
  }
</style>

<script>
  async function loadDashboardData() {
    try {
      const res = await apiFetch('/dashboard/microposts/api');
      const data = await res.json();
      const totalEl = document.getElementById('total-microposts');
      if (totalEl) {
        totalEl.textContent = data.data?.microposts?.length || 0;
      }
    } catch (err) {
      console.error('Failed to load dashboard data:', err);
      const totalEl = document.getElementById('total-microposts');
      if (totalEl) totalEl.textContent = '0';
    }
  }
  loadDashboardData();
</script>
