{
  "name": "typescript-workflow-runner",
  "version": "1.0.0",
  "type": "module",
  "description": "Workflow runner for ordered job execution",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "start:build": "node dist/index.js",
    "hello-world": "tsx src/application/jobs/system/hello-world.ts",
    "db-init": "tsx src/application/jobs/database/db-init.ts",
    "item-crud": "tsx src/application/jobs/database/item-crud.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:logs": "pm2 logs"
  },
  "dependencies": {
    "awilix": "^12.0.5",
    "better-sqlite3": "^11.8.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.8.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.15"
  }
}
